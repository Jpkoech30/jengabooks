generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id              String   @id @default(uuid())
  name            String
  tier            String   @default("BRONZE")
  kraPin          String?
  kraClientId     String?
  isActive        Boolean  @default(true)
  parentCompanyId String?
  parentCompany   Company? @relation("CompanyHierarchy", fields: [parentCompanyId], references: [id])
  childCompanies  Company[] @relation("CompanyHierarchy")
  members         CompanyMember[]
  chartOfAccounts ChartOfAccount[]
  journalEntries  JournalEntry[]
  fiscalPeriods   FiscalPeriod[]
  pendingReviews  PendingReview[]
  invoices        Invoice[]
  mpesaTransactions MpesaTransaction[]
  bankTransactions  BankTransaction[]
  categoryRules   CategoryRule[]
  healthScores    BusinessHealthScore[]
  xpRecords       XPRecord[]
  syncLogs        SyncLog[]
  aiFeedbackLogs  AiFeedbackLog[]
  userLevels      UserLevel[]
  wizardProgress  WizardProgress[]
  auditLogs           AuditLog[]
  statementUploads    StatementUpload[]
  parsingTemplates    ParsingTemplate[]
  auditLocks          AuditLock[]
  externalAccessGrants ExternalAccess[]
  employees         Employee[]
  payrollRuns       PayrollRun[]
  comments          Comment[]
  clientTasks       ClientTask[]
  notifications     Notification[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("companies")
}

model CompanyMember {
  id        String @id @default(uuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id])
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  role      String
  isActive  Boolean @default(true)
  @@unique([userId, companyId])
  @@map("company_members")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  memberships          CompanyMember[]
  postedEntries        JournalEntry[]
  xpRecords            XPRecord[]
  userLevels           UserLevel[]
  assignedReviews      PendingReview[] @relation("AssignedReviews")
  resolvedReviews      PendingReview[] @relation("ResolvedReviews")
  statementUploads     StatementUpload[]
  auditLogs            AuditLog[]
  refreshTokens        RefreshToken[]
  auditLocksLocked     AuditLock[] @relation("AuditLockLocker")
  unlockRequestedLocks AuditLock[] @relation("AuditLockUnlocker")
  externalAccessGrants ExternalAccess[]
  @@map("users")
}

model ChartOfAccount {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  code      String
  name      String
  type      String
  isActive  Boolean  @default(true)
  taxRate   Float?            // VAT rate override: 16 (standard), 8 (reduced), 0 (zero-rated), null (exempt)
  parentId  String?
  parent    ChartOfAccount? @relation("AccountHierarchy", fields: [parentId], references: [id])
  children  ChartOfAccount[] @relation("AccountHierarchy")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  journalEntries JournalEntry[]
  mpesaMappings  MpesaTransaction[]
  bankMappings   BankTransaction[]
  @@unique([companyId, code])
  @@map("chart_of_accounts")
}

model JournalEntry {
  id           String   @id @default(uuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  accountId    String
  account      ChartOfAccount @relation(fields: [accountId], references: [id])
  description  String
  amount       Float
  direction    String
  reference    String?
  serialNumber String?
  entryDate    DateTime
  version      Int      @default(1)
  postedById   String
  postedBy     User     @relation(fields: [postedById], references: [id])
  isReconciled Boolean @default(false)
  aiConfidence Float?
  aiReasoning  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?
  @@map("journal_entries")
}

model FiscalPeriod {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  startDate DateTime
  endDate   DateTime
  status    String   @default("OPEN")
  closedBy  String?
  closedAt  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([companyId, name])
  @@map("fiscal_periods")
}

model Invoice {
  id           String   @id @default(uuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  invoiceNumber String  @unique
  customerName String
  customerPin  String?
  customerEmail String?
  lineItems    Json     @default("[]")
  subtotal     Float
  vat          Float
  total        Float
  taxCode      String   @default("S")
  status       String   @default("DRAFT")
  dueDate      DateTime?
  paidAt       DateTime?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  etimsSubmission ETIMSSubmission?
  @@map("invoices")
}

model ETIMSSubmission {
  id           String   @id @default(uuid())
  invoiceId    String   @unique
  invoice      Invoice  @relation(fields: [invoiceId], references: [id])
  serialNumber String   @unique
  xmlPayload   String
  kraResponse  String?
  status       String   @default("PENDING")
  submittedAt  DateTime?
  retryCount   Int      @default(0)
  lastError    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@map("etims_submissions")
}

model MpesaTransaction {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  receiptNo     String?
  transactionDate DateTime
  description   String
  amount        Float
  paidIn        Float?
  withdrawn     Float?
  phoneNumber   String?
  paybill       String?
  customerName  String?
  transactionType String?
  rawCsv        String?
  mappedAccountId String?
  mappedAccount ChartOfAccount? @relation(fields: [mappedAccountId], references: [id])
  confidence    Float?
  isReconciled  Boolean  @default(false)
  category      String?
  createdAt     DateTime @default(now())
  @@map("mpesa_transactions")
}

model BankTransaction {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  transactionDate DateTime
  description   String
  amount        Float
  reference     String?
  mappedAccountId String?
  mappedAccount ChartOfAccount? @relation(fields: [mappedAccountId], references: [id])
  isReconciled  Boolean  @default(false)
  createdAt     DateTime @default(now())
  @@map("bank_transactions")
}

model CategoryRule {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  keyword     String
  accountCode String
  direction   String?
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("category_rules")
}

model PendingReview {
  id              String   @id @default(uuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  category        String
  description     String
  rawData         String?
  conflictData    String?
  status          String   @default("PENDING")
  assignedTo      String?
  assignedUser    User?    @relation("AssignedReviews", fields: [assignedTo], references: [id])
  resolvedBy      String?
  resolvedUser    User?    @relation("ResolvedReviews", fields: [resolvedBy], references: [id])
  resolvedAt      DateTime?
  xpAwarded       Int      @default(0)
  resolution      String?
  linkedEntityId  String?  // UUID of the related transaction
  linkedEntityType String? // 'MPESA_TX' | 'JOURNAL_ENTRY' | 'INVOICE'
  confidence      Float?   // AI confidence score that triggered the review
  resolutionAction String? // 'APPROVED' | 'REJECTED' | 'EDITED'
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@map("pending_reviews")
}

model XPRecord {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  points    Int
  reason    String
  badge     String?
  createdAt DateTime @default(now())
  @@map("xp_records")
}

model UserLevel {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  level     Int      @default(1)
  totalXp   Int      @default(0)
  updatedAt DateTime @updatedAt
  @@unique([userId, companyId])
  @@map("user_levels")
}

model BusinessHealthScore {
  id           String   @id @default(uuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  overallScore Float
  pillarScores Json
  calculatedAt DateTime @default(now())
  @@map("business_health_scores")
}

model AiFeedbackLog {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  transactionId String?
  agentType     String
  inputData     String
  outputData    String
  reasoning     String?
  wasAccepted   Boolean
  userCorrection String?
  confidence    Float?
  createdAt     DateTime @default(now())
  @@map("ai_feedback_logs")
}

model SyncLog {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  deviceId      String
  entityType    String
  entityId      String
  status        String   @default("PENDING")
  serverVersion Int?
  deviceVersion Int?
  conflictData  String?
  resolvedAt    DateTime?
  createdAt     DateTime @default(now())
  @@map("sync_logs")
}

model AuditLog {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entityType String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  @@index([companyId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model WizardProgress {
  id          String   @id @default(uuid())
  userId      String
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  step        String
  completedAt DateTime @default(now())
  xpAwarded   Int      @default(0)
  badgeAwarded String?

  @@unique([userId, companyId, step])
  @@map("wizard_progress")
}

model StatementUpload {
  id                 String   @id @default(uuid())
  tenantId           String
  company            Company  @relation(fields: [tenantId], references: [id])
  uploadedBy         String
  user               User     @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)
  fileName           String
  filePath           String
  fileType           String
  fileSize           Int
  institution        String   @default("OTHER")
  detectedBy         String   @default("AUTO")
  statementPeriodStart DateTime?
  statementPeriodEnd   DateTime?
  accountNumber      String?
  openingBalance     Float?
  closingBalance     Float?
  totalMoneyIn       Float?   @default(0)
  totalMoneyOut      Float?   @default(0)
  status             String   @default("PENDING_PARSING")
  transactionCount   Int?     @default(0)
  parsedData         Json?
  errorMessage       String?
  templateId         String?
  template           ParsingTemplate? @relation(fields: [templateId], references: [id])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  processedAt        DateTime?

  @@index([tenantId, status, createdAt])
  @@map("statement_uploads")
}

model ParsingTemplate {
  id              String   @id @default(uuid())
  tenantId        String
  company         Company  @relation(fields: [tenantId], references: [id])
  name            String
  institution     String
  fileFormat      String
  columnMapping   Json     @default("{}")
  headerSignature String?
  regexPatterns   Json     @default("[]")
  isActive        Boolean  @default(true)
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  statementUploads StatementUpload[]

  @@index([tenantId, institution])
  @@map("parsing_templates")
}

model Employee {
  id               String    @id @default(uuid())
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id])
  name             String
  email            String?
  phone            String?
  kraPin           String
  nationalId       String?
  nhifNumber       String?
  nssfNumber       String?
  employeeType     String
  taxTreatment     String
  status           String    @default("ACTIVE")
  terminationDate  DateTime?
  hireDate         DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  salaryStructures SalaryStructure[]
  payrollEntries   PayrollEntry[]

  @@index([companyId])
  @@map("employees")
}

model SalaryStructure {
  id            String   @id @default(uuid())
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id])
  effectiveFrom DateTime
  effectiveTo   DateTime?
  basicPay      Float
  housingLevy   Float?
  benefits      Json?
  deductions    Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([employeeId])
  @@map("salary_structures")
}

model PayrollRun {
  id               String    @id @default(uuid())
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id])
  periodStart      DateTime
  periodEnd        DateTime
  status           String    @default("DRAFT")
  totalGrossPay    Float     @default(0)
  totalNetPay      Float     @default(0)
  totalPaye        Float     @default(0)
  totalNhif        Float     @default(0)
  totalNssf        Float     @default(0)
  totalHousingLevy Float     @default(0)
  totalEmployerCost Float    @default(0)
  generatedAt      DateTime  @default(now())
  lockedAt         DateTime?
  filedAt          DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  entries PayrollEntry[]

  @@index([companyId])
  @@map("payroll_runs")
}

model PayrollEntry {
  id              String    @id @default(uuid())
  payrollRunId    String
  payrollRun      PayrollRun @relation(fields: [payrollRunId], references: [id])
  employeeId      String
  employee        Employee   @relation(fields: [employeeId], references: [id])
  grossPay        Float
  basicPay        Float
  benefitsTotal   Float      @default(0)
  deductionsTotal Float      @default(0)
  paye            Float      @default(0)
  nhif            Float      @default(0)
  nssf            Float      @default(0)
  housingLevy     Float      @default(0)
  netPay          Float
  employerNhif    Float      @default(0)
  employerNssf    Float      @default(0)
  employerHousing Float      @default(0)
  status          String     @default("CALCULATED")
  paymentDate     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([payrollRunId])
  @@index([employeeId])
  @@map("payroll_entries")
}

/// Transaction-level chat/comment thread.
/// entityType and entityId reference external records (MPESA_TX, JOURNAL_ENTRY, INVOICE, PAYROLL_ENTRY)
/// without FK constraints â€” comments persist as audit trail even after the entity is deleted.
model Comment {
  id              String   @id @default(uuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  entityType      String   // MPESA_TX, JOURNAL_ENTRY, INVOICE, PAYROLL_ENTRY
  entityId        String   // ID of the transaction/entry being commented on
  authorId        String
  authorName      String
  content         String
  mentions        Json?    // Array of mentioned user IDs: ["user_1", "user_2"]
  attachments     Json?    // Array of { name: string, url: string, type: string }
  status          String   @default("ACTIVE") // ACTIVE, RESOLVED, ESCALATED
  parentId        String?  // For threaded replies (null = top-level)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([companyId])
  @@index([entityType, entityId])
  @@index([parentId])
  @@map("comments")
}

model Subscription {
  id                 String    @id @default(uuid())
  companyId          String    @unique
  tier               String    // STARTER, PRO, ENTERPRISE, ACCOUNTANT_PRACTICE
  status             String    @default("TRIAL") // TRIAL, ACTIVE, EXPIRED, CANCELLED
  trialEndsAt        DateTime?
  currentPeriodStart DateTime  @default(now())
  currentPeriodEnd   DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("subscriptions")
}

/// Auto-generated tasks assigned to clients or team members.
/// Kept even if the referenced client/user is deleted â€” orphaned tasks are marked SKIPPED.
model ClientTask {
  id              String    @id @default(uuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id])
  clientId        String    // The company/target client (no FK â€” kept for audit if client deleted)
  title           String
  description     String?
  category        String    // UPLOAD_DOCUMENT, APPROVE_TRANSACTIONS, SIGN_OFF, PROVIDE_INFO
  priority        String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status          String    @default("PENDING") // PENDING, COMPLETED, SKIPPED, ESCALATED
  assignedToId    String?   // User ID of who needs to do this
  assignedToName  String?
  dueDate         DateTime?
  completedAt     DateTime?
  completedById   String?
  escalationCount Int      @default(0)
  source          String?  // AUTO_GENERATED, MANUAL, SYSTEM
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([companyId])
  @@index([clientId])
  @@index([assignedToId])
  @@index([status])
  @@map("client_tasks")
}

/// Multi-channel notifications for in-app, email, and SMS delivery.
/// Persists even if the recipient user is deleted â€” sender displayed as "System".
model Notification {
  id                String   @id @default(uuid())
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id])
  userId            String   // Recipient
  type              String   // TASK_ASSIGNED, COMMENT_MENTION, DEADLINE_REMINDER, SYSTEM
  title             String
  message           String?
  link              String?  // Deep link to the relevant page
  relatedEntityType String?
  relatedEntityId   String?
  channel           String   @default("IN_APP") // IN_APP, EMAIL, SMS, ALL
  status            String   @default("UNREAD") // UNREAD, READ, DISMISSED
  sentAt            DateTime?
  readAt            DateTime?
  createdAt         DateTime @default(now())

  @@index([companyId])
  @@index([userId, status])
  @@index([createdAt])
  @@map("notifications")
}


model Document {
  id            String   @id @default(uuid())
  companyId     String
  fileName      String
  originalName  String
  fileSize      Int
  mimeType      String
  category      String
  description   String?
  tags          Json?
  uploadedById  String
  isDeleted     Boolean  @default(false)
  currentVersion Int     @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  versions DocumentVersion[]

  @@index([companyId])
  @@index([category])
  @@index([companyId, category])
  @@map("documents")
}

model DocumentVersion {
  id           String   @id @default(uuid())
  documentId   String
  version      Int
  fileName     String
  fileSize     Int
  mimeType     String
  uploadedById String
  createdAt    DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id])

  @@index([documentId])
  @@map("document_versions")
}

/// Fiscal period lock-down for audit compliance.
/// Prevents modifications to financial data within locked periods.
/// Supports FULL, MODULE_SPECIFIC, and ROLE_BASED lock types.
model AuditLock {
  id                  String    @id @default(uuid())
  companyId           String
  company             Company   @relation(fields: [companyId], references: [id])
  fiscalYear          Int       // e.g., 2026
  periodStart         DateTime  // e.g., 2026-01-01
  periodEnd           DateTime  // e.g., 2026-03-31
  lockType            String    // FULL, MODULE_SPECIFIC, ROLE_BASED
  status              String    @default("OPEN") // OPEN, LOCKED, AMENDED
  lockedById          String
  lockedBy            User      @relation("AuditLockLocker", fields: [lockedById], references: [id])
  lockedAt            DateTime?
  unlockReason        String?   // Required for any amendment to locked period
  unlockRequestedById String?
  unlockRequestedBy   User?     @relation("AuditLockUnlocker", fields: [unlockRequestedById], references: [id])
  modules             Json?     // ["LEDGER", "MPESA", "ETIMS", "PAYROLL"] — which modules are locked
  roleOverrides       Json?     // {"ACCOUNTANT": "edit", "SME_OWNER": "view"}
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([companyId, fiscalYear, periodStart])
  @@index([companyId])
  @@index([fiscalYear])
  @@index([companyId, status])
  @@index([companyId, fiscalYear, periodStart, periodEnd])
  @@map("audit_locks")
}

/// Temporary access grants for external auditors, bank officers, and KRA auditors.
/// Each grant has an access token, expiry date, and access level.
model ExternalAccess {
  id              String    @id @default(uuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id])
  grantorId       String
  grantor         User      @relation(fields: [grantorId], references: [id])
  recipientName   String    // e.g., "KRA Auditor", "KCB Bank"
  recipientEmail  String?
  accessLevel     String    // READ_ONLY, VIEW_ONLY, RUN_REPORTS
  accessToken     String    @unique // Unique token for authentication
  expiresAt       DateTime
  lastAccessedAt  DateTime?
  purpose         String    // ANNUAL_AUDIT, LOAN_APPLICATION, KRA_AUDIT, OTHER
  isRevoked       Boolean   @default(false)
  createdAt       DateTime  @default(now())

  accessLogs ExternalAccessLog[]

  @@index([companyId])
  @@index([accessToken])
  @@index([expiresAt])
  @@index([companyId, isRevoked])
  @@map("external_access")
}

/// Audit trail for all actions performed by external access grants.
/// Retained indefinitely for KRA audit compliance.
model ExternalAccessLog {
  id            String   @id @default(uuid())
  accessId      String
  access        ExternalAccess @relation(fields: [accessId], references: [id])
  action        String   // VIEW_REPORT, DOWNLOAD_DOCUMENT, LIST_TRANSACTIONS
  resourceType  String   // REPORT, DOCUMENT, TRANSACTION
  resourceId    String?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([accessId])
  @@index([accessId, createdAt])
  @@map("external_access_logs")
}

