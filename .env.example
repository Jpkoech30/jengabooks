# Database (PostgreSQL)
# Uses localhost — Windows auto-forwards WSL2 ports, so this works
# even when WSL's internal IP changes on reboot
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jengabooks?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=jengabooks-dev-jwt-secret-2026

# DeepSeek AI
DEEPSEEK_API_KEY=your-api-key-here

# KRA eTIMS
KRA_CLIENT_ID=your-client-id
KRA_CLIENT_SECRET=your-client-secret

# CORS
CORS_ORIGIN=http://localhost:5173

# App
PORT=3001
