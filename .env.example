# Database (PostgreSQL)
#
# ── Environment-specific connection strings ──
#
#   🐧 Linux native:              postgresql://postgres:postgres@localhost:5432/jengabooks?schema=public
#   🐳 Windows + Docker Desktop:  postgresql://postgres:postgres@localhost:5432/jengabooks?schema=public
#   🪟 Windows + WSL:             postgresql://postgres:postgres@192.168.1.XX:5432/jengabooks?schema=public&sslmode=disable
#
# For WSL:
#   1. Find the WSL IP: wsl -- ip addr | findstr "inet "  (look for 192.168.1.XXX)
#   2. Replace XX with that IP
#   3. sslmode=disable is required because WSL Postgres doesn't have SSL configured
#
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jengabooks?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-jwt-secret-here

# DeepSeek AI
DEEPSEEK_API_KEY=your-api-key-here

# KRA eTIMS
KRA_CLIENT_ID=your-client-id
KRA_CLIENT_SECRET=your-client-secret

# M-Pesa Daraja API (Safaricom)
# Sandbox: https://sandbox.safaricom.co.ke
# Production: https://api.safaricom.co.ke
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_PASSKEY=your_passkey
MPESA_SHORTCODE=your_paybill_or_till
MPESA_ENVIRONMENT=sandbox  # sandbox | production

# Callback URL for Daraja webhooks (must be publicly accessible in production)
# CALLBACK_BASE_URL=https://your-domain.com

# Default company for processed Daraja webhooks (single-tenant fallback)
# DEFAULT_COMPANY_ID=your-company-uuid

# CORS
CORS_ORIGIN=http://localhost:5173

# App
PORT=3001
