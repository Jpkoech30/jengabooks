# Database (PostgreSQL)
#
# ── Environment-specific connection strings ──
#
#   🐧 Linux native:              postgresql://postgres:postgres@localhost:5432/jengabooks?schema=public
#   🐳 Windows + Docker Desktop:  postgresql://postgres:postgres@localhost:5432/jengabooks?schema=public
#   🪟 Windows + WSL:             postgresql://postgres:postgres@192.168.1.XX:5432/jengabooks?schema=public&sslmode=disable
#
# For WSL:
#   1. Find the WSL IP: wsl -- ip addr | findstr "inet "  (look for 192.168.1.XXX)
#   2. Replace XX with that IP
#   3. sslmode=disable is required because WSL Postgres doesn't have SSL configured
#
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jengabooks?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=jengabooks-dev-jwt-secret-2026

# DeepSeek AI
DEEPSEEK_API_KEY=your-api-key-here

# KRA eTIMS
KRA_CLIENT_ID=your-client-id
KRA_CLIENT_SECRET=your-client-secret

# CORS
CORS_ORIGIN=http://localhost:5173

# App
PORT=3001
