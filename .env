# Database (PostgreSQL running in WSL) — localhost works because Windows auto-forwards WSL2 ports
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jengabooks?schema=public"

# Redis (running in WSL) — same localhost forwarding applies
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=dev-jwt-secret-jengabooks-2026

# DeepSeek AI
DEEPSEEK_API_KEY=placeholder

# KRA eTIMS
KRA_CLIENT_ID=placeholder
KRA_CLIENT_SECRET=placeholder

# CORS
CORS_ORIGIN=http://localhost:5173

# App
PORT=3001
